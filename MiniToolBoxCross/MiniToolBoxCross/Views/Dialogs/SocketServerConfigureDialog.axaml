<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="MiniToolBoxCross.Views.Dialogs.SocketServerConfigureDialog"
    x:DataType="vm:SocketServerConfigureDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:vm="clr-namespace:MiniToolBoxCross.ViewModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16" RowDefinitions="Auto, *, Auto">
        <TextBlock
            FontSize="16"
            FontWeight="600"
            Grid.Row="0"
            Text="{Binding Title}" />

        <u:Form
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            LabelPosition="Top">
            <u:Form.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid ColumnDefinitions="2*,1*" RowDefinitions="Auto, Auto, Auto, Auto" />
                </ItemsPanelTemplate>
            </u:Form.ItemsPanel>

            <u:FormItem Label="服务器 Ip">
                <ComboBox HorizontalAlignment="Stretch" SelectedItem="{Binding ServerIp}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="1"
                Grid.Row="0"
                Label="服务器端口"
                Margin="16,8,0,0">
                <NumericUpDown
                    Maximum="65535"
                    Minimum="0"
                    Value="{Binding ServerPort}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="0"
                Grid.Row="1"
                Label="本地 Ip">
                <ComboBox HorizontalAlignment="Stretch" SelectedItem="{Binding LocalIp}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="1"
                Grid.Row="1"
                Label="本地端口"
                Margin="16,8,0,8">
                <NumericUpDown
                    Maximum="65535"
                    Minimum="0"
                    Value="{Binding LocalPort}" />
            </u:FormItem>
        </u:Form>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Margin="0,16,0,0"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Classes="Danger"
                Command="{Binding CancelCommand}"
                Content="返回" />
            <Button Command="{Binding CreateCommand}" Content="确定" />
        </StackPanel>
    </Grid>
</UserControl>