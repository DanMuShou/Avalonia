<UserControl
    mc:Ignorable="d"
    x:Class="MiniToolBoxCross.Views.Dialogs.ForwardConfigureDialog"
    x:DataType="vm:ForwardConfigureDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="clr-namespace:MiniToolBoxCross.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:vm="clr-namespace:MiniToolBoxCross.ViewModels.Dialogs"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converters:EnumToTypeConverter x:Key="EnumToTypeConverter" />
    </UserControl.Resources>
    <Grid
        Margin="16"
        MinHeight="300"
        MinWidth="450"
        RowDefinitions="*,Auto">
        <u:Form
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            LabelPosition="Top">
            <u:Form.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid ColumnDefinitions="5*,3*" RowDefinitions="Auto,Auto,Auto" />
                </ItemsPanelTemplate>
            </u:Form.ItemsPanel>

            <u:FormItem
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="0"
                Label="名称">
                <TextBox Text="{Binding ForwardName}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="0"
                Grid.Row="1"
                Label="转发 Ip">
                <ComboBox
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding IpAddressList}"
                    SelectedItem="{Binding ForwardIp}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="1"
                Grid.Row="1"
                Label="转发端口"
                Margin="16,8,0,0">
                <NumericUpDown
                    Maximum="65535"
                    Minimum="1024"
                    Value="{Binding ForwardPort}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="0"
                Grid.Row="2"
                Label="目标">
                <u:EnumSelector
                    EnumType="{Binding ForwardTargetType, Converter={StaticResource EnumToTypeConverter}}"
                    HorizontalAlignment="Stretch"
                    Value="{Binding ForwardTargetType}" />
            </u:FormItem>

            <u:FormItem
                Grid.Column="1"
                Grid.Row="2"
                Label=""
                Margin="16,8,0,0">
                <ToggleButton
                    Content="使用Tcp"
                    HorizontalAlignment="Stretch"
                    IsChecked="{Binding IsTcp}"
                    IsEnabled="False" />
            </u:FormItem>
        </u:Form>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Margin="0,16,0,0"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Classes="Danger"
                Command="{Binding CancelCommand}"
                Content="返回" />
            <Button
                Classes="Primary"
                Command="{Binding CreateCommand}"
                Content="确定" />
        </StackPanel>
    </Grid>
</UserControl>
