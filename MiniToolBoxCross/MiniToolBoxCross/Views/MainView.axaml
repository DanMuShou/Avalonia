<UserControl
    d:DesignHeight="350"
    d:DesignWidth="450"
    mc:Ignorable="d"
    x:Class="MiniToolBoxCross.Views.MainView"
    x:DataType="vm:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pa="using:MiniToolBoxCross.Views.Pages"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:vm="using:MiniToolBoxCross.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer HorizontalAlignment="Stretch">
            <TabControl HorizontalAlignment="Stretch">
                <TabItem Header="主机">
                    <pa:ForwardHostView DataContext="{Binding ForwardHostViewModel}" />
                </TabItem>
                <TabItem Header="客机">
                    <pa:ForwardClientView DataContext="{Binding ForwardClientViewModel}" />
                </TabItem>
            </TabControl>
        </ScrollViewer>
        <u:OverlayDialogHost HorizontalAlignment="Stretch" />
    </Grid>
</UserControl>
