<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="MiniToolBoxCross.Views.Pages.SocketClientView"
    x:DataType="vm:SocketClientViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MiniToolBoxCross.ViewModels.Pages"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Theme="{DynamicResource CardBorder}">
        <ScrollViewer>
            <Grid RowDefinitions="Auto, 1*">
                <Grid ColumnDefinitions="Auto,1*" RowDefinitions="1*,4,1*,4,1*">
                    <TextBlock
                        Grid.Column="0"
                        Grid.Row="0"
                        Text="IP地址: "
                        VerticalAlignment="Center" />
                    <TextBox
                        Grid.Column="1"
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        Text="{Binding IpAddress}" />

                    <TextBlock
                        Grid.Column="0"
                        Grid.Row="2"
                        Text="端口: "
                        VerticalAlignment="Center" />
                    <NumericUpDown
                        Grid.Column="1"
                        Grid.Row="2"
                        Maximum="65535"
                        Minimum="0"
                        Value="{Binding Port}" />

                    <StackPanel
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Grid.Row="4"
                        Orientation="Horizontal">
                        <Button
                            Classes="Tertiary"
                            Command="{Binding PasteIpCommand}"
                            Content="粘贴" />
                        <Button
                            Command="{Binding ConnectCommand}"
                            Content="连接"
                            Margin="4,0,0,0" />
                        <Button
                            Classes="Danger"
                            Command="{Binding DisconnectCommand}"
                            Content="断开"
                            Margin="4,0,0,0" />
                        <Button
                            Classes="Success"
                            Command="{Binding PingCommand}"
                            Content="Ping"
                            Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Border>
